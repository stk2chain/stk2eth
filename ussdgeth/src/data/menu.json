{
	"menus": {
		"InitialScreen": {
			"text": "Welcome to M-ETH",
			"screen_type": "Initial",
			"default_next_screen": "MainScreen"
		},
		"MainScreen": {
			"text": "M-ETH Main Menu\n1. Send ETH\n2. Swap\n3. Withdraw Cash\n4. Buy Airtime\n5. My Account\n6. Check Balance",
			"screen_type": "Menu",
			"default_next_screen": "DefaultNoneScreen",
			"menu_items": {
				"SendETHOption": {
					"option": "1",
					"display_name": "Send ETH",
					"next_screen": "SendETHAmountScreen"
				},
				"SwapOption": {
					"option": "2",
					"display_name": "Swap",
					"next_screen": "SwapScreen"
				},
				"WithdrawOption": {
					"option": "3",
					"display_name": "Withdraw Cash",
					"next_screen": "WithdrawScreen"
				},
				"AirtimeOption": {
					"option": "4",
					"display_name": "Buy Airtime",
					"next_screen": "AirtimeScreen"
				},
				"AccountOption": {
					"option": "5",
					"display_name": "My Account",
					"next_screen": "AccountScreen"
				},
				"BalanceOption": {
					"option": "6",
					"display_name": "Check Balance",
					"next_screen": "BalanceScreen"
				}
			}
		},
		"DefaultNoneScreen": {
			"text": "Thank you for using M-ETH",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},
		"SendETHAmountScreen": {
			"text": "Enter ETH amount:",
			"screen_type": "Input",
			"input_identifier": "eth_amount",
			"default_next_screen": "SendETHRecipientScreen"
		},
		"SendETHRecipientScreen": {
			"text": "Enter recipient address:",
			"screen_type": "Input",
			"input_identifier": "recipient_address",
			"default_next_screen": "SendETHConfirmScreen"
		},
		"SendETHConfirmScreen": {
			"text": "Confirm Send:\nAmount: {{eth_amount}} ETH\nTo: {{recipient_address}}\nFee: {{gas_fee}} ETH\n\n1. Confirm\n2. Cancel",
			"screen_type": "Menu",
			"menu_items": {
				"ConfirmOption": {
					"option": "1",
					"display_name": "Confirm",
					"next_screen": "SendETHPINScreen"
				},
				"CancelOption": {
					"option": "2",
					"display_name": "Cancel",
					"next_screen": "MainScreen"
				}
			},
			"default_next_screen": "MainScreen"
		},
		"SendETHPINScreen": {
			"text": "Enter your PIN to authorize transaction:",
			"screen_type": "Input",
			"input_identifier": "user_pin",
			"default_next_screen": "SendETHProcessScreen"
		},
		"SendETHProcessScreen": {
			"text": "Processing transaction...\nPlease wait.",
			"screen_type": "Function",
			"function": "process_send_eth",
			"default_next_screen": "SendETHRouterScreen"
		},
		"SendETHRouterScreen": {
			"text": "Selecting result...",
			"screen_type": "Router",
			"router_options": [
				{
					"router_option": "{{send_eth.status == 'success'}}",
					"next_screen": "SendETHSuccessScreen"
				},
				{
					"router_option": "{{send_eth.status == 'failed'}}",
					"next_screen": "SendETHFailureScreen"
				},
				{
					"router_option": "{{send_eth.status == 'error'}}",
					"next_screen": "SendETHFailureScreen"
				}
			],
			"default_next_screen": "DefaultNoneScreen"
		},
		"SendETHSuccessScreen": {
			"text": "✓ ETH sent successfully!\nTx Hash: {{tx_hash}}\nAmount: {{eth_amount}} ETH\nFee: {{gas_fee}} ETH",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},
		"SendETHFailureScreen": {
			"text": "✗ Transaction failed\nReason: {{error_message}}\n\nPlease try again.",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},
		"BalanceScreen": {
			"text": "Processing balance check...",
			"screen_type": "Function",
			"function": "check_balance",
			"default_next_screen": "BalanceDisplayScreen"
		},
		"BalanceDisplayScreen": {
			"text": "Account Balance:\n{{balance}} ETH\n\nPress any key to continue",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},
		"AccountScreen": {
			"text": "My Account\n1. View Address\n2. Transaction History\n3. Settings\n0. Back",
			"screen_type": "Menu",
			"menu_items": {
				"ViewAddressOption": {
					"option": "1",
					"display_name": "View Address",
					"next_screen": "ViewAddressScreen"
				},
				"HistoryOption": {
					"option": "2",
					"display_name": "Transaction History",
					"next_screen": "HistoryScreen"
				},
				"SettingsOption": {
					"option": "3",
					"display_name": "Settings",
					"next_screen": "SettingsScreen"
				},
				"BackOption": {
					"option": "0",
					"display_name": "Back",
					"next_screen": "MainScreen"
				}
			},
			"default_next_screen": "MainScreen"
		},
		"ViewAddressScreen": {
			"text": "Your ETH Address:\n{{wallet_address}}\n\nPress any key to continue",
			"screen_type": "Quit",
			"default_next_screen": "AccountScreen"
		},
		"OwnNumberRouterScreen": {
			"text": "Selecting...",
			"screen_type": "Router",
			"router": "AirtimeScreen",
			"router_options": [
				{
					"router_option": "{{airtime.status == 'success'}}",
					"next_screen": "SuccessScreen"
				},
				{
					"router_option": "{{airtime.status == 'failed'}}",
					"next_screen": "FailureScreen"
				},
				{
					"router_option": "{{airtime.status == 'error'}}",
					"next_screen": "FailureScreen"
				}
			],
			"default_next_screen": "DefaultNoneScreen"
		}

	}
	,
	"services": {
		"buy_airtime": {
			"function_name": "buy_airtime",
			"function_url": "http://localhost:3000/buy_airtime",
			"data_key": "airtime"
		},
		"send_eth": {
			"function_name": "send_eth",
			"function_url": null,
			"data_key": "send_eth"
		}
	}
}
