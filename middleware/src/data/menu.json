{
	"menus": {
		"InitialScreen": {
			"text": "Welcome to M-ETH",
			"screen_type": "Initial",
			"default_next_screen": "MainScreen"
		},
		"RegisterScreen": {
			"text": "Welcome to M-ETH.",
			"screen_type": "Menu",
			"default_next_screen": "MainScreen",
			"menu_items": {
				"RegisterOption": {
					"option":"1",
					"display_name":"Register",
					"next_screen":"RegisterPinScreen"
				},
				"CancelOption": {
					"option":"2",
					"display_name":"Cancel",
					"next_screen":"DefaultNoneScreen"
				}
			}
		},
		"RegisterPinScreen": {
			"text": "Register PIN:",
			"screen_type": "Function",
			"function": "register_pin",
			"default_next_screen": "ConfirmRegisterPinScreen"
		},
		"ConfirmRegisterPinScreen": {
			"text": "Confirm PIN:",
			"screen_type": "Function",
			"function": "confirm_register_pin",
			"default_next_screen": "RegisterSuccessScreen"
		},
		"RegisterSuccessScreen": {
			"text": "Registration Complete!\nRedial to Continue.",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},
		"MainScreen": {
			"text": "M-ETH",
			"screen_type": "Menu",
			"default_next_screen": "DefaultNoneScreen",
			"menu_items": {
				"SendETHOption": {
					"option": "1",
					"display_name": "Send ETH",
					"next_screen": "ToNumberScreen"
				},
				"SwapOption": {
					"option": "2",
					"display_name": "Swap",
					"next_screen": "SwapTokenScreen"
				},
				"WithdrawOption": {
					"option": "3",
					"display_name": "Withdraw",
					"next_screen": "WithdrawAmountScreen"
				},
				"BalanceOption": {
					"option": "4",
					"display_name": "Balance",
					"next_screen": "BalancePinScreen"
				},
				"AccountOption": {
					"option": "5",
					"display_name": "Account",
					"next_screen": "AccountScreen"
				}
			}
		},
		"DefaultNoneScreen": {
			"text": "Thank you for using M-ETH",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},

        "ToNumberScreen": {
			"text": "Enter Phone No.:",
			"screen_type": "Function",
			"function": "validate_phone_number",
			"default_next_screen": "ToAmountScreen"
		},
		"ToAmountScreen": {
			"text": "Amount:",
			"screen_type": "Function",
			"function": "validate_amount",
			"default_next_screen": "PINScreen"
		},
        "PINScreen": {
			"text": "PIN:",
			"screen_type": "Function",
			"function": "validate_pin",
			"default_next_screen": "CancelTXScreen"
		},
        "CancelTXScreen": {
			"text": "",
			"screen_type": "Function",
			"function": "cancel_tx",
			"default_next_screen": "SuccessScreen"
		},
		"SuccessScreen": {
			"text": "Transaction Successful",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},
		"FailureScreen": {
			"text": "Transaction Failed",
			"screen_type": "Quit",
			"default_next_screen": "MainScreen"
		},
		"SwapTokenScreen": {
			"text": "Enter Token: (ie. ETH, USDC)",
			"screen_type": "Function",
			"function": "validate_token",
			"default_next_screen": "SwapTokenAmountScreen"
		},
		"SwapTokenAmountScreen": {
			"text": "Amount:",
			"screen_type": "Function",
			"function": "validate_amount",
			"default_next_screen": "SwapTokenPinScreen"
		},
		"SwapTokenReceiverScreen": {
			"text": "Receiver",
			"screen_type": "Function",
			"function": "validate_phone_number",
			"default_next_screen": "SwapTokenPinScreen"
		},
		"SwapTokenPinScreen": {
			"text": "PIN:",
			"screen_type": "Function",
			"function": "validate_pin",
			"default_next_screen": "CancelTXScreen"
		},
		"BalancePinScreen": {
			"text": "PIN:",
			"screen_type": "Function",
			"function": "validate_pin",
			"default_next_screen": "DefaultNoneScreen"
		},
		"WithdrawAmountScreen": {
			"text": "Amount:",
			"screen_type": "Function",
			"function": "validate_amount",
			"default_next_screen": "WithdrawPinScreen"
		},
		"WithdrawPinScreen": {
			"text": "PIN:",
			"screen_type": "Function",
			"function": "validate_pin",
			"default_next_screen": "DefaultNoneScreen"
		},
		"AccountScreen": {
			"text": "My Account:",
			"screen_type": "Menu",
			"default_next_screen": "DefaultNoneScreen",
			"menu_items": {
				"BaseToken": {
					"option": "1",
					"display_name": "Base Token",
					"next_screen": "DefaultNoneScreen"
				},
				"InstantWithdraw": {
					"option": "2",
					"display_name": "Instant Withdraw",
					"next_screen": "DefaultNoneScreen"
				},
				"Address": {
					"option": "3",
					"display_name": "Address",
					"next_screen": "DefaultNoneScreen"
				}													
			}
		}
	}
	,
	"services": {
		"register_pin": {
			"function_name": "register_pin"
		},
		"confirm_register_pin": {
			"function_name": "confirm_register_pin"
		},
		"validate_phone_number": {
			"function_name": "validate_phone_number"
		},
		"validate_amount": {
			"function_name": "validate_amount"
		},
		"validate_pin": {
			"function_name": "validate_pin"
		},
		"cancel_tx": {
			"function_name": "cancel_tx"
		},
		"validate_token": {
			"function_name": "validate_token"
		}
	}
}
